# Copy to `.env` and fill in values.

# HTTP port for the Node server (default 3000).
PORT=3000

# Base URL shown to players after room code validation (omit to use http://localhost:PORT).
# Example: https://jeopardy.example.com
PUBLIC_BASE_URL=

# SQLite database path (default: ./data/clues.db).
# CLUES_DB_PATH=./data/clues.db

# Optional URL for gzipped j-archive-parser JSON (default: howardchung/j-archive-parser release).
# Used when players pick a tournament episode type (Kids Week, Teen, etc.); episodes are imported into clues.db once.
# JEOPARDY_PACK_URL=

# --- OpenAI answer judging (optional) ---
# If OPENAI_API_KEY is set and OPENAI_ANSWER_JUDGE_ENABLED is true, responses that
# fail the local heuristic are sent to the API for a second opinion (spelling,
# nicknames, "close enough" wording). No key = heuristic only.

OPENAI_API_KEY=
# Any model your key can use with Chat Completions + JSON schema (e.g. gpt-4o-mini).
OPENAI_MODEL=gpt-4o-mini
OPENAI_ANSWER_JUDGE_ENABLED=true

# Implemented in lib/aiAnswerJudge.js: chat.completions.create with
# response_format type json_schema (strict), schema { correct: boolean } only.
