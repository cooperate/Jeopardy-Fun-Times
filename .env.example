# Copy to `.env` and fill in values.

# HTTP port for the Node server (default 3000).
PORT=3000

# Base URL shown to players after room code validation (omit to use http://localhost:PORT).
# Example: https://jeopardy.example.com
PUBLIC_BASE_URL=

# SQLite database path (default: ./data/clues.db).
# CLUES_DB_PATH=./data/clues.db

# --- OpenAI answer judging (optional) ---
# If OPENAI_API_KEY is set and OPENAI_ANSWER_JUDGE_ENABLED is true, responses that
# fail the local heuristic are sent to the API for a second opinion (spelling,
# nicknames, "close enough" wording). No key = heuristic only.

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_ANSWER_JUDGE_ENABLED=true

# API request shape (for reference — implemented in lib/aiAnswerJudge.js):
# POST https://api.openai.com/v1/chat/completions
# Headers: Authorization: Bearer <OPENAI_API_KEY>, Content-Type: application/json
# Body: {
#   "model": "<OPENAI_MODEL>",
#   "temperature": 0,
#   "messages": [
#     { "role": "system", "content": "<Jeopardy judge instructions + JSON-only reply>" },
#     { "role": "user", "content": "{\"clue\":\"...\",\"officialAnswer\":\"...\",\"contestantResponse\":\"...\"}" }
#   ]
# }
# Expected assistant content: {"correct":true|false,"reason":"short explanation"}
